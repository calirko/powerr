#pragma once

// Copy this file to secrets.h and fill in your values. secrets.h is gitignored.

#define WIFI_SSID "your-wifi-ssid"
#define WIFI_PASSWORD "your-wifi-password"

// Server the device connects out to (must match server/.env AUTH_TOKEN).
#define SERVER_HOST "your.server.host"
#define SERVER_PORT 3000
#define SERVER_USE_TLS false // set true if the server sits behind TLS (wss://)
#define AUTH_TOKEN "change-me-to-a-long-random-secret"

// LAN IP of the motherboard's NIC, used to ping-probe whether the PC itself
// is powered on (separate from whether this ESP32 is online). Give it a
// static/reserved DHCP lease so this doesn't drift.
#define PC_HOST_IP "192.168.1.50"
